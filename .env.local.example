# ─────────────────────────────────────────────
# MOTO CARE PRO — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────

# Supabase — get these from https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# App
NEXT_PUBLIC_APP_NAME="Moto Care Pro"
NEXT_PUBLIC_GARAGE_NAME="Moto Care Pro - Chennai"
NEXT_PUBLIC_GARAGE_PHONE="9876543210"
